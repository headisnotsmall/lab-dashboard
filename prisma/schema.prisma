generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Device {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  location      String        @default("")
  systemState   String        @default("閒置")
  cpuInfo       String        @default("")
  ramInfo       String        @default("")
  storageInfo   String        @default("")
  gpuInfo       String        @default("")
  aocInfo       String        @default("")
  ip            String        @default("")
  bmcIp         String        @default("")
  osStatus      String        @default("")
  serialNumber  String        @default("")
  bmcMac        String        @default("")
  unipassword   String        @default("")
  bmcVersion    String        @default("")
  biosVersion   String        @default("")
  operator      String        @default("")
  borrowedBy    String        @default("")
  borrowedSince DateTime?
  borrowUntil   DateTime?
  borrowReason  String        @default("")
  borrowDescription String    @default("")
  notes         String        @default("")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  reservations  Reservation[]
  incidents     Incident[]
  borrowHistory BorrowHistory[]
}

model StateOption {
  id    Int    @id @default(autoincrement())
  name  String @unique
  order Int    @default(0)
}

model BorrowHistory {
  id        Int      @id @default(autoincrement())
  deviceId  Int
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  borrower  String
  operator  String   @default("")
  fromDate  DateTime?
  toDate    DateTime @default(now())
  reason    String   @default("")
  createdAt DateTime @default(now())
}

model Reservation {
  id        Int      @id @default(autoincrement())
  deviceId  Int
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  borrower  String
  fromDate  DateTime
  toDate    DateTime
  reason    String   @default("")
  createdAt DateTime @default(now())
}

model Incident {
  id          Int      @id @default(autoincrement())
  deviceId    Int
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  title       String
  description String   @default("")
  occurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())
}
